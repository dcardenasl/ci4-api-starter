includes:
    - phpstan-baseline.neon

rules:
    - App\PHPStan\Rules\ServiceDtoFirstRule

parameters:
    level: 8
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - app/Controllers
        - app/Services
        - app/Models
        - app/Libraries
        - app/Entities
        - app/Filters
        - app/Interfaces
    parallel:
        jobSize: 20
        processTimeout: 600.0
        maximumNumberOfProcesses: 0
        minimumNumberOfJobsPerProcess: 2
        buffer: 134217728
    excludePaths:
        - vendor
        - writable
        - tests/_support (?)
        - app/Config
        - app/Views
        - app/Commands
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    # ignoreErrors limited to CI4 framework-dynamic patterns (not real bugs).
    # Tech-debt-style errors (missingType.iterableValue, real argument.type
    # mismatches) are captured in phpstan-baseline.neon below and shrunk over
    # time. New errors of those kinds will fail CI.
    ignoreErrors:
        # CI4 helper functions and framework constants are stubbed in
        # phpstan-bootstrap.php. ENVIRONMENT is deliberately left undefined there
        # so `ENVIRONMENT === 'production'` stays runtime-unknown (not always-false).
        - '#Constant ENVIRONMENT not found#'
        # CI4 query builder + magic methods
        - '#Call to an undefined method CodeIgniter\\Database\\BaseBuilder::#'
        # CI4 Entity dynamic properties (Entity uses __get/__set)
        - '#Access to an undefined property App\\Entities\\.*::\$#'
        # CI4 controller magic methods (request, response, etc.)
        - '#Call to an undefined method App\\Controllers\\.*::(request|response|getVarString|getGetString|getVarInt|respondForbidden)\(\)#'
        # Generic object access — appears when a service returns mixed-shape
        # untyped data; should be progressively typed but not blocking.
        - '#Call to an undefined method object::#'
        - '#Access to an undefined property object::#'
